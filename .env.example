# Overflod usa Node.js + Express.js.
# Modo local: guarda datos en data/overflod.local.json para demostraciones sin instalar SQL Server.
DB_ENGINE=local
LOCAL_DB_PATH=data/overflod.local.json

# Modo Microsoft SQL Server:
# DB_ENGINE=sqlserver
# SQLSERVER_SERVER=localhost,1433
# SQLSERVER_DATABASE=Overflod
# SQLSERVER_USER=sa
# SQLSERVER_PASSWORD=TuPasswordSeguro
# SQLSERVER_ENCRYPT=yes
# SQLSERVER_TRUST_CERTIFICATE=yes

# Tambien puedes usar una cadena compatible con el paquete mssql:
# SQLSERVER_CONNECTION_STRING=Server=localhost,1433;Database=Overflod;User Id=sa;Password=TuPasswordSeguro;Encrypt=true;TrustServerCertificate=true
